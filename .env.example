# ============================================================
# Employee Help — Environment Variables
# ============================================================
# Copy this file to .env and fill in values.
# NEVER commit .env to source control.
# ============================================================

# Required — Anthropic API key for LLM generation
ANTHROPIC_API_KEY=sk-ant-...

# CORS — comma-separated allowed origins (default: localhost for dev)
# CORS_ORIGINS=https://your-app.vercel.app

# Rate limiting
# RATE_LIMIT_MAX=5            # per-IP requests per window for /api/ask
# RATE_LIMIT_WINDOW=60        # window in seconds
# FEEDBACK_RATE_LIMIT_MAX=10  # per-IP feedback requests per minute
# DAILY_QUERY_BUDGET=500      # total /api/ask queries per day (all IPs)

# Railway sets PORT automatically
# PORT=8000

# ── Authentication (Phase A1) ──────────────────────────────
# Required for user authentication. Generate JWT secret with:
#   python -c "import secrets; print(secrets.token_hex(32))"
AUTH_JWT_SECRET=
AUTH_ACCESS_TOKEN_TTL=900        # 15 minutes in seconds (default)
AUTH_REFRESH_TOKEN_TTL=604800    # 7 days in seconds (default)

# Google OAuth — from Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth — from Azure Portal > App Registrations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
