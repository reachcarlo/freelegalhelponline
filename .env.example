# ============================================================
# Employee Help — Environment Variables
# ============================================================
# Copy this file to .env and fill in values.
# NEVER commit .env to source control.
# ============================================================

# Required — Anthropic API key for LLM generation
ANTHROPIC_API_KEY=sk-ant-...

# CORS — comma-separated allowed origins (default: localhost for dev)
# CORS_ORIGINS=https://your-app.vercel.app

# Rate limiting
# RATE_LIMIT_MAX=5            # per-IP requests per window for /api/ask
# RATE_LIMIT_WINDOW=60        # window in seconds
# FEEDBACK_RATE_LIMIT_MAX=10  # per-IP feedback requests per minute
# DAILY_QUERY_BUDGET=500      # total /api/ask queries per day (all IPs)

# Railway sets PORT automatically
# PORT=8000
